generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?

  @@index([shop, isOnline, expires])
  @@index([shop, expires])
}

model Registration {
  id           String    @id @default(cuid())
  shop         String
  customerId   String?
  email        String
  firstName    String
  lastName     String
  phone        String?
  company      String?
  status       String    @default("pending")
  customData   Json?
  note         String?
  reviewedAt   DateTime?
  reviewedBy   String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  passwordHash String?

  @@index([shop])
  @@index([status])
  @@index([email])
  @@index([shop, status])
  @@index([shop, createdAt])
  @@index([status, createdAt])
  @@index([shop, status, createdAt])
  // Customer list: filter by shop+status, order by createdAt DESC (avoids sort step).
  @@index([shop, status, createdAt(sort: Desc)], map: "Registration_shop_status_createdAt_desc_idx")
  // Duplicate email checks on registration submit.
  @@index([shop, email], map: "Registration_shop_email_idx")
  // Customer list orders by createdAt DESC — a descending index avoids a sort step.
  // Explicit `map` so Prisma does not collide with the ascending [shop, createdAt] index name.
  @@index([shop, createdAt(sort: Desc)], map: "Registration_shop_createdAt_desc_idx")
  // `customerId` stores the Shopify Customer GID; lookups (reconcile, dedupe) hit this hot.
  @@index([customerId])
  // Detail/reconcile code paths usually filter by both shop and customerId.
  @@index([shop, customerId], map: "Registration_shop_customerId_idx")
}

model AppSettings {
  id                       String   @id @default(cuid())
  shop                     String   @unique
  defaultLanguage          String   @default("en")
  languageOptions          Json     @default("[]")
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
  formTranslations         Json?
  translationInProgress    String?
  customCss                String?
  themeSettings            Json?
  /// Customer approval + storefront copy: successMessage, pendingRegistrationScreenTitle, pendingRegistrationScreenMessage, etc.
  customerApprovalSettings Json?
  /// ISO country code used as default for phone/country UX (e.g. "US", "IN").
  shopCountryCode          String?
  /// basic | standard | premium — gates features (Shopify Billing can update later).
  merchantPlan             String   @default("standard")
}

model B2BSettings {
  id           String   @id @default(cuid())
  shop         String   @unique
  approvalTag  String   @default("wholesale")
  orderMinimum String?
  orderMaximum String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model FormConfig {
  id        String   @id @default(cuid())
  shop      String
  fields    Json     @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  name      String
  formType  String
  isDefault Boolean  @default(false)
  enabled   Boolean  @default(true)
  /// Multi-step forms only: show progress bar + % on storefront. Ignored for wholesale (single-step).
  showProgressBar Boolean @default(true)
  /// Large title above the form on the storefront. Empty = use Settings → translations default.
  storefrontHeading     String?
  /// Subtitle under the title. Empty = use translation default.
  storefrontDescription String?
  /// Shopify customer tags applied when a shopper submits this form (JSON string array).
  customerTags          Json     @default("[]")

  @@index([shop])
  @@index([shop, isDefault])
  @@index([shop, isDefault, enabled], map: "FormConfig_shop_isDefault_enabled_idx")
}

model SmtpSettings {
  id               String   @id @default(cuid())
  shop             String   @unique
  host             String
  port             Int      @default(587)
  secure           Boolean  @default(false)
  user             String?
  passwordEncrypted String?
  fromEmail        String
  fromName         String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([shop])
}

model EmailTemplate {
  id        String   @id @default(cuid())
  shop      String
  slug      String
  name      String
  subject   String
  bodyHtml  String   @default("")
  bodyText  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([shop, slug])
  @@index([shop])
}
