# Copy to `.env` and fill secrets. Never commit `.env`.

SHOPIFY_FLAG_THEME_APP_EXTENSION_PORT=9294

# Partners dashboard → your app → Settings → Credentials
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SCOPES=write_products,read_customers,write_customers,write_app_proxy,read_locales,read_online_store_pages,write_online_store_pages,read_themes,write_themes
SHOPIFY_APP_URL=https://approvefy.vercel.app

# Supabase pooled (PgBouncer) URL — port 6543 + ?pgbouncer=true&connection_limit=1
# Required for serverless: each Vercel lambda must hold only 1 pooled connection.
DATABASE_URL=
# Supabase direct URL — port 5432, session-mode. Used by `prisma migrate` only.
DIRECT_URL=

SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_UPLOAD_BUCKET=b2b-uploads

RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Optional: Crisp live chat in embedded admin (defaults to Approvefy widget if unset)
CRISP_WEBSITE_ID=
