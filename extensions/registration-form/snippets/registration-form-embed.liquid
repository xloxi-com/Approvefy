{% # theme-check-disable OrphanedSnippet, UndefinedObject, MissingAsset, ParserBlockingScript %}
{% liquid
  assign approvefy_load_form = load_registration_form
  if approvefy_load_form == nil
    assign approvefy_load_form = true
  endif
%}
{{ 'guest-checkout-guard.css' | asset_url | stylesheet_tag }}
{% if approvefy_load_form %}
  {{ 'registration-form.css' | asset_url | stylesheet_tag }}
{% endif %}
<script>
window.__REGISTRATION_FORM_CONFIG__ = {
  embedFormId: {{ block.settings.form_id | default: '' | json }},
  pendingMessage: { en: {{ block.settings.pending_message | json }}, fr: {{ block.settings.pending_message_fr | default: block.settings.pending_message | json }} },
  shop: {{ shop.permanent_domain | json }},
  shopCountryCode: {{ shop.address.country_code | default: localization.country.iso_code | default: "US" | json }},
  customerLoggedIn: {% if customer %}true{% else %}false{% endif %},
  customerTags: {% if customer %}{{ customer.tags | json }}{% else %}[]{% endif %},
  customerEmail: {% if customer %}{{ customer.email | default: '' | json }}{% else %}""{% endif %},
  customerFirstName: {% if customer %}{{ customer.first_name | default: '' | json }}{% else %}""{% endif %},
  customerLastName: {% if customer %}{{ customer.last_name | default: '' | json }}{% else %}""{% endif %},
  shopifyLoggedInCustomerId: {% if customer %}{{ customer.id | json }}{% else %}null{% endif %},
  contactPageUrl: {% if pages.contact != blank and pages.contact.url != blank %}{{ pages.contact.url | json }}{% else %}{{ routes.root_url | append: 'pages/contact' | json }}{% endif %},
  registrationPagePath: {% assign approvefy_reg_page = pages['customer-registration'] %}{% if approvefy_reg_page != blank and approvefy_reg_page.url != blank %}{{ approvefy_reg_page.url | json }}{% else %}{{ '/pages/customer-registration' | json }}{% endif %}
};
window.__approvefySignInRedirectEnabled = true;
(function () {
  var cfg = window.__REGISTRATION_FORM_CONFIG__;
  if (!cfg || !cfg.shop) return;
  var shop = cfg.shop;
  var embedFormId = typeof cfg.embedFormId === 'string' ? cfg.embedFormId.trim() : '';
  var formIdParam = embedFormId ? '&formId=' + encodeURIComponent(embedFormId) : '';
  var themeEditorPreviewParam = {% if request.design_mode %} '&themeEditorPreview=1'{% else %} ''{% endif %};
  var loc = (document.documentElement.lang || '').toLowerCase().split('-')[0];
  if (!loc) {
    var pathMatch = window.location.pathname.match(/^\/([a-z]{2})(\/|$)/);
    loc = pathMatch ? pathMatch[1].toLowerCase() : '';
  }
  if (!loc) loc = 'en';
  function resolveLoggedInShopifyCustomerId() {
    if (
      cfg.shopifyLoggedInCustomerId != null &&
      String(cfg.shopifyLoggedInCustomerId).trim() !== ''
    ) {
      return String(cfg.shopifyLoggedInCustomerId).trim();
    }
    try {
      var stGlobal = typeof __st !== 'undefined' ? __st : window.__st;
      if (stGlobal && stGlobal.cid != null && String(stGlobal.cid).trim() !== '') {
        return String(stGlobal.cid).trim();
      }
    } catch (eSt) {
      void eSt;
    }
    try {
      if (window.Shopify && window.Shopify.customer && window.Shopify.customer.id != null) {
        var shopifyCustomerId = String(window.Shopify.customer.id).trim();
        if (shopifyCustomerId) {
          return shopifyCustomerId;
        }
      }
    } catch (eShopifyCustomer) {
      void eShopifyCustomer;
    }
    try {
      var analyticsId =
        window.ShopifyAnalytics &&
        window.ShopifyAnalytics.meta &&
        window.ShopifyAnalytics.meta.page &&
        window.ShopifyAnalytics.meta.page.customerId;
      if (analyticsId != null && String(analyticsId).trim() !== '') {
        return String(analyticsId).trim();
      }
    } catch (eAnalytics) {
      void eAnalytics;
    }
    try {
      var meta = document.querySelector(
        'meta[name="shopify-customer-id"], meta[name="customer-id"]'
      );
      if (meta) {
        var metaId = (meta.getAttribute('content') || '').trim();
        if (metaId) {
          return metaId;
        }
      }
    } catch (eMeta) {
      void eMeta;
    }
    return '';
  }
  function fetchCustomerIdFromCart() {
    return fetch('/cart.js', { credentials: 'same-origin', cache: 'no-store' })
      .then(function (r) {
        return r.ok ? r.json() : null;
      })
      .then(function (cart) {
        if (
          cart &&
          cart.customer_id != null &&
          String(cart.customer_id).trim() !== '' &&
          Number(cart.customer_id) > 0
        ) {
          return String(cart.customer_id).trim();
        }
        return '';
      })
      .catch(function () {
        return '';
      });
  }
  function waitForLoggedInCustomerId(maxMs, stepMs) {
    return new Promise(function (resolve) {
      var deadline = Date.now() + (maxMs || 3000);
      function attempt() {
        var id = resolveLoggedInShopifyCustomerId();
        if (id) {
          resolve(id);
          return;
        }
        if (Date.now() >= deadline) {
          fetchCustomerIdFromCart().then(function (cartId) {
            resolve(cartId || '');
          });
          return;
        }
        setTimeout(attempt, stepMs || 50);
      }
      attempt();
    });
  }

  function buildConfigUrl(resolvedLoggedInCustomerId) {
    var customerShopifyIdParam = resolvedLoggedInCustomerId
      ? '&customerShopifyId=' + encodeURIComponent(resolvedLoggedInCustomerId)
      : '';
    var customerEmailParam =
      resolvedLoggedInCustomerId && cfg.customerEmail && String(cfg.customerEmail).trim() !== ''
        ? '&customerEmail=' + encodeURIComponent(String(cfg.customerEmail).trim())
        : '';
    return (
      '/apps/customer-approval/config?shop=' +
      encodeURIComponent(shop) +
      '&locale=' +
      encodeURIComponent(loc) +
      formIdParam +
      themeEditorPreviewParam +
      customerShopifyIdParam +
      customerEmailParam
    );
  }

  var CONFIG_CACHE_TTL_MS = 5 * 60 * 1000;

  function configCacheKeyForCustomer(resolvedLoggedInCustomerId) {
    return (
      'customer_approval_config_v13_' +
      shop +
      '_' +
      embedFormId +
      '_' +
      loc +
      '_' +
      (resolvedLoggedInCustomerId || '0')
    );
  }

  function tryReadCachedConfig(customerId) {
    try {
      if (!window.sessionStorage) return null;
      var key = configCacheKeyForCustomer(customerId || '0');
      var raw = sessionStorage.getItem(key);
      if (!raw) {
        var legacyPrefix = key + '_';
        for (var ci = 0; ci < sessionStorage.length; ci++) {
          var legacyKey = sessionStorage.key(ci);
          if (legacyKey && legacyKey.indexOf(legacyPrefix) === 0) {
            raw = sessionStorage.getItem(legacyKey);
            break;
          }
        }
      }
      if (!raw) return null;
      var parsed = JSON.parse(raw);
      if (!parsed || typeof parsed !== 'object') return null;
      if (parsed.ts && Date.now() - parsed.ts > CONFIG_CACHE_TTL_MS) return null;
      return parsed.data && typeof parsed.data === 'object' ? parsed.data : null;
    } catch (eCacheRead) {
      void eCacheRead;
      return null;
    }
  }

  function storeConfigCache(data, customerId) {
    try {
      if (!data || typeof data !== 'object' || !window.sessionStorage) return;
      sessionStorage.setItem(
        configCacheKeyForCustomer(customerId || '0'),
        JSON.stringify({ ts: Date.now(), data: data })
      );
    } catch (eStore) {
      void eStore;
    }
  }

  function applyThemeCss(cssText) {
    if (typeof cssText !== 'string' || !cssText.trim()) return;
    var existing = document.getElementById('customer-approval-theme-style');
    if (existing) {
      while (existing.firstChild) existing.removeChild(existing.firstChild);
      existing.appendChild(document.createTextNode(cssText));
      return;
    }
    var styleEl = document.createElement('style');
    styleEl.id = 'customer-approval-theme-style';
    styleEl.type = 'text/css';
    styleEl.appendChild(document.createTextNode(cssText));
    document.head.appendChild(styleEl);
  }

  function fetchAndCacheConfig(configUrl, fetchOpts) {
    return fetch(configUrl, fetchOpts)
      .then(function (r) {
        if (!r.ok)
          throw new Error(
            'Approvefy config failed (HTTP ' + r.status + '). Verify app proxy prefix /apps/customer-approval in Partner Dashboard.'
          );
        return r.json();
      })
      .then(function (data) {
        if (data && typeof data.customCss === 'string') applyThemeCss(data.customCss);
        var resolvedId = resolveLoggedInShopifyCustomerId();
        storeConfigCache(data, resolvedId || '0');
        return data;
      });
  }

  function startNetworkConfig(customerId) {
    var url = buildConfigUrl(customerId || '');
    window.__approvefyConfigPrefetchUrl = url;
    return fetchAndCacheConfig(url, { credentials: 'same-origin', cache: 'no-store' });
  }

  var syncCustomerId = resolveLoggedInShopifyCustomerId();
  var knownLoggedIn =
    cfg.customerLoggedIn === true ||
    (syncCustomerId && String(syncCustomerId).trim() !== '');
  var cacheCustomerKey =
    syncCustomerId ||
    (cfg.shopifyLoggedInCustomerId != null && String(cfg.shopifyLoggedInCustomerId).trim() !== ''
      ? String(cfg.shopifyLoggedInCustomerId).trim()
      : '0');
  var cachedConfig = tryReadCachedConfig(cacheCustomerKey);
  if (cachedConfig && typeof cachedConfig.customCss === 'string') {
    applyThemeCss(cachedConfig.customCss);
  }

  var guestConfigUrl = buildConfigUrl('');
  window.__approvefyConfigPrefetchUrl = guestConfigUrl;
  var initialConfigFetch = fetchAndCacheConfig(guestConfigUrl, {
    credentials: 'same-origin',
  });

  if (cachedConfig) {
    var refreshPromise;
    if (knownLoggedIn && !syncCustomerId && !cfg.shopifyLoggedInCustomerId) {
      refreshPromise = waitForLoggedInCustomerId(400, 25).then(function (resolvedLoggedInCustomerId) {
        if (resolvedLoggedInCustomerId) {
          cfg.customerLoggedIn = true;
          cfg.shopifyLoggedInCustomerId = resolvedLoggedInCustomerId;
          window.__REGISTRATION_FORM_CONFIG__ = cfg;
          return startNetworkConfig(resolvedLoggedInCustomerId);
        }
        return initialConfigFetch;
      });
    } else if (knownLoggedIn && (syncCustomerId || cfg.shopifyLoggedInCustomerId)) {
      var loggedInId = syncCustomerId || String(cfg.shopifyLoggedInCustomerId);
      cfg.customerLoggedIn = true;
      cfg.shopifyLoggedInCustomerId = loggedInId;
      window.__REGISTRATION_FORM_CONFIG__ = cfg;
      refreshPromise = startNetworkConfig(loggedInId);
    } else {
      refreshPromise = initialConfigFetch;
    }
    window.__approvefyConfigPromise = Promise.resolve(cachedConfig);
    refreshPromise
      .then(function (fresh) {
        window.__approvefyConfigPromise = Promise.resolve(fresh);
      })
      .catch(function () {});
  } else if (knownLoggedIn) {
    if (syncCustomerId || cfg.shopifyLoggedInCustomerId) {
      var immediateLoggedInId = syncCustomerId || String(cfg.shopifyLoggedInCustomerId);
      cfg.customerLoggedIn = true;
      cfg.shopifyLoggedInCustomerId = immediateLoggedInId;
      window.__REGISTRATION_FORM_CONFIG__ = cfg;
      window.__approvefyConfigPromise = startNetworkConfig(immediateLoggedInId);
    } else {
      window.__approvefyConfigPromise = waitForLoggedInCustomerId(400, 25).then(function (resolvedLoggedInCustomerId) {
        if (resolvedLoggedInCustomerId) {
          cfg.customerLoggedIn = true;
          cfg.shopifyLoggedInCustomerId = resolvedLoggedInCustomerId;
          window.__REGISTRATION_FORM_CONFIG__ = cfg;
          return startNetworkConfig(resolvedLoggedInCustomerId);
        }
        return initialConfigFetch;
      });
    }
  } else {
    window.__approvefyConfigPromise = initialConfigFetch;
  }

  {% if approvefy_load_form %}
  (function paintCachedFormHtmlEarly() {
    var mount = document.querySelector(
      '[data-approvefy-registration-block] .approvefy-registration-mount'
    );
    if (!mount || mount.getAttribute('data-approvefy-prepainted') === '1') return;
    try {
      if (!window.sessionStorage) return;
      var htmlKey =
        'customer_approval_rendered_form_v13_' +
        shop +
        '_' +
        embedFormId +
        '_' +
        loc +
        '_' +
        (cacheCustomerKey || '0');
      var raw = sessionStorage.getItem(htmlKey);
      if (!raw && window.localStorage) raw = localStorage.getItem(htmlKey);
      if (!raw) return;
      var parsed = JSON.parse(raw);
      if (!parsed || typeof parsed.html !== 'string' || !parsed.html.trim()) return;
      if (parsed.ts && Date.now() - parsed.ts > 30 * 60 * 1000) return;
      mount.innerHTML = parsed.html;
      mount.setAttribute('data-approvefy-prepainted', '1');
      document.body.classList.add('custom-registration-enabled');
    } catch (ePaint) {
      void ePaint;
    }
  })();
  {% endif %}
})();
</script>
<script>
(function () {
  var cfg = window.__REGISTRATION_FORM_CONFIG__;
  if (!cfg || !cfg.shop) return;

  function pathWithoutLocale(pathname) {
    var p = pathname || '/';
    var m = p.toLowerCase().match(/^(\/[a-z]{2}(?:-[a-z]{2})?)(\/.*|$)/);
    if (m && m[1] && m[1].length <= 6) {
      return m[2] && m[2].length > 0 ? m[2] : '/';
    }
    return p;
  }

  function norm(path) {
    var raw = String(path || '').trim();
    if (!raw) return '/';
    try {
      if (raw.indexOf('http://') === 0 || raw.indexOf('https://') === 0 || raw.indexOf('//') === 0) {
        raw = new URL(raw.indexOf('//') === 0 ? 'https:' + raw : raw).pathname || '/';
      }
    } catch (eNorm) {
      void eNorm;
    }
    return (pathWithoutLocale(raw.split('?')[0]).replace(/\/+$/, '') || '/').toLowerCase();
  }

  function isRegistrationPage() {
    var current = norm(window.location.pathname);
    if (/\/pages\/customer-registration\/?$/i.test(current)) return true;
    var paths = ['/pages/customer-registration'];
    if (cfg.registrationPagePath) paths.push(cfg.registrationPagePath);
    var i;
    for (i = 0; i < paths.length; i++) {
      if (norm(paths[i]) === current) return true;
    }
    return false;
  }

  function homeHref() {
    try {
      if (window.Shopify && window.Shopify.routes && window.Shopify.routes.root) {
        return window.Shopify.routes.root;
      }
    } catch (eHome) {
      void eHome;
    }
    return '/';
  }

  if (!isRegistrationPage()) return;

  function leaveIfDisabled(cas) {
    if (cas && cas.redirectSignInLinksToFormPage === true) return;
    var home = homeHref();
    if (norm(window.location.pathname) !== norm(home)) {
      window.location.replace(home);
    }
  }

  var promise = window.__approvefyConfigPromise;
  if (promise && typeof promise.then === 'function') {
    promise.then(function (data) {
      leaveIfDisabled(data && data.customerApprovalSettings);
    }).catch(function () {});
  }
})();
</script>
{{ 'guest-checkout-guard.js' | asset_url | preload_tag: as: 'script' }}
{% if approvefy_load_form %}
  {{ 'registration-form.js' | asset_url | preload_tag: as: 'script' }}
  <script src="{{ 'registration-form.js' | asset_url }}" defer fetchpriority="high"></script>
{% endif %}
<script src="{{ 'guest-checkout-guard.js' | asset_url }}" defer></script>
